# ============================================================

# .gitignore — track only what's needed to restore the project

#

# Tracked: scripts/, small metadata, project files, README

# Excluded: everything that can be downloaded or regenerated

# ============================================================



# --- R / RStudio ---

.Rhistory

.RData

.Rproj.user/



# --- Large binary files (all regenerated by pipeline) ---

*.rds

*.RDS

*.h5ad

*.h5seurat

*.loom

*.mtx

*.mtx.gz

*.tsv.gz



# --- Raw data (downloaded from GEO + Allen) ---

raw_data/



# --- All generated output directories ---

processed/

result/

export/

shiny_data/



# --- Old / scratch ---

archive/

practice/



# --- Large metadata (downloaded from Allen) ---

metadata/reference_metadata.csv



# --- SynGO source files (only processed CSVs needed) ---

metadata/synGO/*.xlsx

metadata/synGO/*.zip



# --- System files ---

.DS_Store

Thumbs.db



# ============================================================

# What IS tracked (for reference):

#

#   scripts/                              all 37 R scripts

#   metadata/GSE140511_sample_metadata.csv

#   metadata/reference_dendrogram.RData

#   metadata/synGO/syngo_TERM2GENE.csv

#   metadata/synGO/syngo_TERM2NAME.csv

#   scRNA.Rproj

#   .gitignore

#   README.md

# ============================================================
